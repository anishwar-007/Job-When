# Supabase (required for auth and data)
# Get these from your Supabase project: Settings > API
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key

# Production site URL (set in Vercel so OAuth redirect goes to your app, not localhost)
# REACT_APP_SITE_URL=https://job-when.vercel.app

# Resend (for sending email from the app - set in Vercel Environment Variables)
# Get API key from https://resend.com - required for "Send email" from tracker
# RESEND_API_KEY=re_xxxxx
# Optional: custom from address (must be verified in Resend). Default: onboarding@resend.dev
# RESEND_FROM=Offer When <notifications@yourdomain.com>
